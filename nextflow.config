manifest {
    name            = 'angelovangel/nxf-alignment'
    author          = 'angelovangel'
    homePage        = 'https://github.com/angelovangel/nxf-alignment'
    defaultBranch   = 'main'
    description     = 'A Nextflow pipeline for basecalling, aligning, and analyzing long-read sequencing data (ONT/PacBio)'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04'
    version         = 'v0.6.9'
}


params {

    outdir = 'output'
    model = 'hac'
    help = ""
    basecall = false
    report = false
    sylph = false
    
    pod5 = null
    herro = false
    bed = null
    reads = null // Parameter for reads when basecalling is skipped
    ref = null // when alignment is skipped
    mmap2 = "-ax map-ont"
    asfile = null
    samplename = null
    
    snp = false
    snp_caller = "clair3" 
    deepvariant_model = "ONT_R104" //WGS,WES,PACBIO,ONT_R104,HYBRID_PACBIO_ILLUMINA
    clair3_platform = "ont" // ont, hifi, ilmn
    clair3_model = "r1041_e82_400bps_hac_v500"
    // r1041_e82_400bps_hac_v410, r1041_e82_400bps_hac_v500, r1041_e82_400bps_sup_v410, r1041_e82_400bps_sup_v500, r1041_e82_400bps_sup_v430_bacteria_finetuned
    // hifi_revio, hifi_sequel2, ilmn
    sv = false
    phase = false
    annotate = false
    anno_db = "hg38"
    anno_filterQ = 20
    mods = false
    mods_filter = 5 // based on coverage - Nvalidcov
    pgx = false
    population = 'EUR' // AAC, AME, EAS, EUR, LAT, NEA, OCE, SAS, SSA

    // barcoded case
    kit = null
    samplesheet = null //csv with columns sample,barcode

    cpus = 64
}

profiles {
    standard {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withName: 'DORADO_BASECALL|DORADO_BASECALL_BARCODING|DORADO_ALIGN|DORADO_CORRECT|VCF_CLAIR3|MODKIT|CONVERT_READS' {
                cpus = params.cpus
                containerOptions = '-u $(id -u):$(id -g) --gpus all'
            }
            withName: 'VCF_DEEPVARIANT' {
                cpus = params.cpus
                container = 'docker.io/google/deepvariant:1.10.0-beta-gpu'
                containerOptions = '-u $(id -u):$(id -g) --gpus 1'
            }
            withName: 'DEEPTOOLS_BIGWIG|VCF_SNIFFLES2|VCF_PHASE|READ_ANI|SYLPH_SKETCH_REF' {
                cpus = params.cpus
            }
        }
    }

    nogpu {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        process {
            withName: 'DORADO_BASECALL|DORADO_BASECALL_BARCODING|DORADO_ALIGN|DORADO_CORRECT|MODKIT|DEEPTOOLS_BIGWIG|VCF_SNIFFLES2|VCF_PHASE|CONVERT_READS|READ_ANI|SYLPH_SKETCH_REF' {
                cpus = params.cpus
            }
            withName: 'VCF_CLAIR3' {
                cpus = params.cpus
                container = 'docker.io/hkubal/clair3:v1.2.0'
            }
            withName: 'VCF_DEEPVARIANT' {
                cpus = params.cpus
                container = 'docker.io/google/deepvariant:1.10.0-beta'
            }
        }
    }
    
    test {
        params.pod5 = "${projectDir}/demo/pod5"
        params.asfile = "${projectDir}/demo/as_decisions.csv"
        params.model = "fast"
        params.ref = "${projectDir}/demo/ref.fasta"
        params.bed = "${projectDir}/demo/regions.bed"
        params.snp = true
        params.sv = true
    }

    dev {
        params.model = "fast"
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
        // for testing on Apple Silicon, use local dorado because docker --gpus is not supported
        process {
            withName: 'DORADO_BASECALL|DORADO_BASECALL_BARCODING|DORADO_CORRECT|DORADO_ALIGN|CONVERT_READS' {
                cpus = 8
                container = null
            }
            withName: 'VCF_SNIFFLES2|VCF_PHASE|MODKIT' {
                cpus = 8
            }
            withName: 'VCF_DEEPVARIANT' {
               cpus = 8
               container = 'docker.io/google/deepvariant:1.10.0-beta'
            }
            withName: 'VCF_CLAIR3' {
                cpus = 8
                container = 'docker.io/hkubal/clair3:v1.2.0'
            }
            withName: 'READ_ANI|SYLPH_SKETCH_REF' {
                cpus = 8
                containerOptions = '--platform linux/amd64'
            }
        }
    }

    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.cacheDir = "$HOME/singularity-cache"
        process {
            withName: 'DORADO_BASECALL|DORADO_BASECALL_BARCODING|DORADO_ALIGN|DORADO_CORRECT|DEEPTOOLS_BIGWIG|VCF_CLAIR3|VCF_SNIFFLES2|VCF_PHASE|CONVERT_READS|READ_ANI|SYLPH_SKETCH_REF' {
                cpus = params.cpus
                containerOptions = '--nv'
            }
            withName: 'VCF_DEEPVARIANT' {
                cpus = params.cpus
                container = 'docker.io/google/deepvariant:1.10.0-beta-gpu'
                containerOptions = '--nv'
            }
        }
    }

    revio {
        params.mmap2 = "-ax map-hifi"
        params.clair3_platform = "hifi"
        params.clair3_model = "hifi_revio"
        params.deepvariant_model = "PACBIO"
    }
}
